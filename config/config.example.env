# Provider script from providers/<name>.sh.
PROVIDER="codex"

# Destination for generated Markdown files.
OUTPUT_DIR="$HOME/Documents/YouTube Summaries"

# Prompt template from prompts/ or an absolute path.
PROMPT_TEMPLATE="detailed-summary.md"

# Summary language is currently enforced by the prompt template.
SUMMARY_LANGUAGE="ru"

# Preferred transcript languages. Manual transcripts are preferred over auto-generated transcripts.
PREFERRED_TRANSCRIPT_LANGS="pl,ru,en"
ALLOW_ANY_TRANSCRIPT_LANGUAGE="true"

# Open the saved Markdown file with the default app.
OPEN_AFTER_SAVE="false"

# Codex provider timeout.
CODEX_TIMEOUT_SECONDS="900"

# MVP behavior for long transcripts: fail before calling the provider.

# info or debug.
LOG_LEVEL="info"
