# Provider for the CLI: "codex" (default), "claude", or "fake" (no model call).
# Both real providers shell out to the matching CLI and use your own
# subscription (no API key).
PROVIDER="codex"

# Destination for generated Markdown files.
OUTPUT_DIR="$HOME/Documents/YouTube Summaries"

# Output language for the summary. Any language name works (e.g. English, Russian, 日本語).
# The legacy key SUMMARY_LANGUAGE is still honored when OUTPUT_LANGUAGE is unset.
OUTPUT_LANGUAGE="English"

# Transcript selection is automatic: TubeFold always uses the video's original
# spoken language (inferred from the auto-generated track), preferring a manual
# transcript over the auto-generated one. The summary language is OUTPUT_LANGUAGE
# above, independent of the transcript. ALLOW_ANY_TRANSCRIPT_LANGUAGE decides
# whether to fall back to any available track when the original can't be inferred.
ALLOW_ANY_TRANSCRIPT_LANGUAGE="true"

# Open the saved Markdown file with the default app.
OPEN_AFTER_SAVE="false"

# Codex provider (PROVIDER="codex").
CODEX_TIMEOUT_SECONDS="900"
CODEX_MODEL="gpt-5.4-mini"

# Claude Code provider (PROVIDER="claude").
# CLAUDE_MODEL accepts an alias: sonnet, opus, haiku.
CLAUDE_TIMEOUT_SECONDS="900"
CLAUDE_MODEL="sonnet"
