# Provider script from providers/<name>.sh. Built-in: "codex" or "claude".
# Both shell out to the matching CLI and use your own subscription (no API key).
PROVIDER="codex"

# Destination for generated Markdown files.
OUTPUT_DIR="$HOME/Documents/YouTube Summaries"

# Prompt template from prompts/ or an absolute path.
PROMPT_TEMPLATE="detailed-summary.md"

# Output language for the summary. Any language name works (e.g. English, Russian, 日本語).
# The legacy key SUMMARY_LANGUAGE is still honored when OUTPUT_LANGUAGE is unset.
OUTPUT_LANGUAGE="English"

# Preferred transcript languages. Manual transcripts are preferred over auto-generated transcripts.
PREFERRED_TRANSCRIPT_LANGS="pl,ru,en"
ALLOW_ANY_TRANSCRIPT_LANGUAGE="true"

# Open the saved Markdown file with the default app.
OPEN_AFTER_SAVE="false"

# Codex provider (PROVIDER="codex").
CODEX_TIMEOUT_SECONDS="900"
CODEX_MODEL="gpt-5.4-mini"
CODEX_REASONING_EFFORT="medium"

# Claude Code provider (PROVIDER="claude").
# CLAUDE_MODEL accepts an alias (sonnet, opus, haiku) or a full model id.
# CLAUDE_REASONING_EFFORT: low, medium, high, xhigh, max.
CLAUDE_TIMEOUT_SECONDS="900"
CLAUDE_MODEL="sonnet"
CLAUDE_REASONING_EFFORT="medium"

# MVP behavior for long transcripts: fail before calling the provider.

# info or debug.
LOG_LEVEL="info"
