#!/usr/bin/env python3
from __future__ import annotations

import argparse
import importlib.util
import json
import os
import shutil
import subprocess
import sys
import tempfile
from pathlib import Path
from typing import Any


PROJECT_ROOT = Path(__file__).resolve().parents[1]
SCRIPTS_DIR = PROJECT_ROOT / "scripts"
sys.path.insert(0, str(SCRIPTS_DIR))

from tubefold_lib import (  # noqa: E402
    expand_path,
    metadata_fields,
    model_label,
    normalize_youtube_url,
    parse_bool,
    parse_env_file,
    parse_youtube_video_id,
    processed_at_now,
    strip_outer_markdown_fence,
    tubefold_footer_markdown,
    unique_markdown_path,
    validate_provider_response,
    yaml_front_matter,
)


DEFAULT_CONFIG = {
    "PROVIDER": "codex",
    "OUTPUT_DIR": "$HOME/Documents/YouTube Summaries",
    "PROMPT_TEMPLATE": "detailed-summary.md",
    "OUTPUT_LANGUAGE": "English",
    "PREFERRED_TRANSCRIPT_LANGS": "pl,ru,en",
    "ALLOW_ANY_TRANSCRIPT_LANGUAGE": "true",
    "OPEN_AFTER_SAVE": "false",
    "CODEX_TIMEOUT_SECONDS": "900",
    "CODEX_MODEL": "gpt-5.4-mini",
    "CODEX_REASONING_EFFORT": "medium",
    "CLAUDE_TIMEOUT_SECONDS": "900",
    "CLAUDE_MODEL": "sonnet",
    "CLAUDE_REASONING_EFFORT": "medium",
    "LOG_LEVEL": "info",
}


class UserError(Exception):
    def __init__(self, message: str, exit_code: int = 1) -> None:
        super().__init__(message)
        self.exit_code = exit_code


class Logger:
    def __init__(self, verbose: bool = False) -> None:
        self.verbose = verbose

    def info(self, message: str) -> None:
        print(f"[INFO] {message}", file=sys.stderr)

    def debug(self, message: str) -> None:
        if self.verbose:
            print(f"[DEBUG] {message}", file=sys.stderr)


def main() -> int:
    parser = build_arg_parser()
    args = parser.parse_args()

    logger = Logger(verbose=args.verbose)
    temp_dir: Path | None = None
    keep_temp = bool(args.keep_temp)

    try:
        config = load_config(args)
        if config.get("LOG_LEVEL", "").casefold() == "debug":
            logger.verbose = True

        logger.info("Validating URL")
        video_id = parse_youtube_video_id(args.url)
        url = normalize_youtube_url(args.url)

        validate_dependencies(config, args)

        temp_dir = Path(tempfile.mkdtemp(prefix="tubefold-"))
        logger.debug(f"Temp directory: {temp_dir}")

        metadata_json = temp_dir / "metadata.json"
        if args.metadata_json:
            logger.info("Using provided metadata JSON")
            shutil.copyfile(expand_path(args.metadata_json), metadata_json)
        else:
            logger.info("Fetching video metadata")
            if shutil.which("yt-dlp") is None:
                logger.info("yt-dlp is not installed; using fallback metadata")
                write_fallback_metadata(metadata_json, video_id, url)
            else:
                try:
                    run_checked([str(SCRIPTS_DIR / "get-video-metadata.sh"), url, str(metadata_json)], logger)
                except UserError as error:
                    logger.info(f"Metadata fetch failed; using fallback metadata: {error}")
                    write_fallback_metadata(metadata_json, video_id, url)

        metadata = json.loads(metadata_json.read_text(encoding="utf-8"))
        fields = metadata_fields(metadata, url)

        transcript_file = temp_dir / "transcript.txt"
        transcript_info_json = temp_dir / "transcript-info.json"
        if args.transcript_file:
            logger.info("Using provided transcript file")
            source_transcript = expand_path(args.transcript_file)
            if not source_transcript.exists():
                raise UserError(f"Transcript file does not exist: {source_transcript}")
            shutil.copyfile(source_transcript, transcript_file)
            transcript_info = {
                "language": args.transcript_language or "provided",
                "language_code": args.transcript_language or "provided",
                "is_generated": False,
            }
        else:
            logger.info("Fetching transcript")
            run_checked(
                [
                    str(SCRIPTS_DIR / "fetch-transcript.py"),
                    video_id,
                    str(transcript_file),
                    str(transcript_info_json),
                    "--preferred-langs",
                    config["PREFERRED_TRANSCRIPT_LANGS"],
                    "--allow-any",
                    config["ALLOW_ANY_TRANSCRIPT_LANGUAGE"],
                ]
                + (
                    ["--requested-language", args.requested_transcript_language]
                    if args.requested_transcript_language
                    else []
                ),
                logger,
            )
            transcript_info = json.loads(transcript_info_json.read_text(encoding="utf-8"))
            generated_label = "auto" if transcript_info.get("is_generated") else "manual"
            logger.info(f"Selected transcript: {transcript_info['language_code']} {generated_label}")

        transcript = transcript_file.read_text(encoding="utf-8")
        transcript_size = len(transcript)
        logger.info(f"Transcript size: {transcript_size} characters")

        prompt_template = resolve_prompt_template(config["PROMPT_TEMPLATE"])
        prompt_file = temp_dir / "prompt.md"
        logger.info("Rendering prompt")
        run_checked(
            [
                str(SCRIPTS_DIR / "render-prompt.py"),
                str(prompt_template),
                str(metadata_json),
                str(transcript_file),
                transcript_language_label(transcript_info),
                str(prompt_file),
                "--fallback-url",
                url,
                "--output-language",
                config["OUTPUT_LANGUAGE"],
            ],
            logger,
        )

        provider_name = config["PROVIDER"]
        provider_path = resolve_provider(provider_name)
        provider_output = temp_dir / "provider-output.md"
        logger.info(f"Running provider: {provider_name}")
        if provider_name == "codex":
            logger.info(
                "Codex settings: "
                f"model={config['CODEX_MODEL']} reasoning_effort={config['CODEX_REASONING_EFFORT']}"
            )
        elif provider_name == "claude":
            logger.info(
                "Claude settings: "
                f"model={config['CLAUDE_MODEL']} reasoning_effort={config['CLAUDE_REASONING_EFFORT']}"
            )
        provider_env = os.environ.copy()
        provider_env.update(config)
        run_checked([str(provider_path), str(prompt_file), str(provider_output)], logger, env=provider_env)

        response = strip_outer_markdown_fence(provider_output.read_text(encoding="utf-8", errors="replace"))
        validate_provider_response(response)

        output_dir = expand_path(config["OUTPUT_DIR"])
        ensure_writable_dir(output_dir)
        final_path = unique_markdown_path(output_dir, fields["title"]).resolve()

        logger.info("Saving Markdown")
        final_path.write_text(
            build_markdown(fields, transcript_info, provider_name, prompt_template, response, config),
            encoding="utf-8",
        )
        logger.info(f"Created: {final_path}")

        if parse_bool(config["OPEN_AFTER_SAVE"], default=False):
            logger.info("Opening created file")
            subprocess.run(["open", str(final_path)], check=False)

        print(final_path)
        return 0
    except UserError as error:
        print(f"[ERROR] {error}", file=sys.stderr)
        return error.exit_code
    except subprocess.CalledProcessError as error:
        print(f"[ERROR] Command failed with exit code {error.returncode}: {' '.join(error.cmd)}", file=sys.stderr)
        if error.stderr:
            print(error.stderr.strip(), file=sys.stderr)
        return error.returncode or 1
    except Exception as error:
        print(f"[ERROR] {error}", file=sys.stderr)
        return 1
    finally:
        if temp_dir and temp_dir.exists():
            if keep_temp:
                print(f"[INFO] Temp directory kept: {temp_dir}", file=sys.stderr)
            else:
                shutil.rmtree(temp_dir, ignore_errors=True)


def build_arg_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="tubefold",
        description="Create a Markdown summary for a YouTube video through a provider CLI.",
    )
    parser.add_argument("url", help="YouTube video URL")
    parser.add_argument("--provider", help="Provider name from providers/<name>.sh")
    parser.add_argument("--output-dir", help="Directory where Markdown summaries are saved")
    parser.add_argument("--prompt", dest="prompt_template", help="Prompt template path or prompts/<name>")
    parser.add_argument("--language", dest="output_language", help="Output language for the summary (e.g. English, Russian)")
    parser.add_argument("--codex-model", help="Codex model slug for provider=codex")
    parser.add_argument("--codex-reasoning-effort", help="Codex reasoning effort: minimal, low, medium, high, xhigh")
    parser.add_argument("--claude-model", help="Claude model alias for provider=claude (e.g. sonnet, opus, haiku)")
    parser.add_argument("--claude-effort", help="Claude effort level: low, medium, high, xhigh, max")
    parser.add_argument("--open", dest="open_after_save", action="store_true", default=None, help="Open result after save")
    parser.add_argument("--no-open", dest="open_after_save", action="store_false", help="Do not open result after save")
    parser.add_argument("--verbose", action="store_true", help="Print diagnostic details to stderr")
    parser.add_argument("--keep-temp", action="store_true", help="Keep temporary files for debugging")
    parser.add_argument("--config", help="Path to config.env")
    parser.add_argument("--metadata-json", help=argparse.SUPPRESS)
    parser.add_argument("--transcript-file", help=argparse.SUPPRESS)
    parser.add_argument("--transcript-language", help=argparse.SUPPRESS)
    parser.add_argument("--requested-transcript-language", help=argparse.SUPPRESS)
    parser.add_argument("--subtitle-file", dest="transcript_file", help=argparse.SUPPRESS)
    parser.add_argument("--subtitle-language", dest="transcript_language", help=argparse.SUPPRESS)
    return parser


def load_config(args: argparse.Namespace) -> dict[str, str]:
    config = dict(DEFAULT_CONFIG)
    config_path = expand_path(args.config) if args.config else expand_path(
        os.environ.get("TUBEFOLD_CONFIG", "~/.config/tubefold/config.env")
    )

    file_config: dict[str, str] = {}
    if config_path.exists():
        file_config = parse_env_file(config_path)
        config.update(file_config)
        apply_legacy_keys(config, file_config)

    for key in DEFAULT_CONFIG:
        if key in os.environ:
            config[key] = os.environ[key]
    env_legacy = {
        key: os.environ[key]
        for key in ("SUBTITLE_LANGS", "ALLOW_ANY_SUBTITLE_LANGUAGE", "SUMMARY_LANGUAGE", "OUTPUT_LANGUAGE")
        if key in os.environ
    }
    apply_legacy_keys(config, env_legacy)

    cli_values = {
        "PROVIDER": args.provider,
        "OUTPUT_DIR": args.output_dir,
        "PROMPT_TEMPLATE": args.prompt_template,
        "OUTPUT_LANGUAGE": args.output_language,
        "CODEX_MODEL": args.codex_model,
        "CODEX_REASONING_EFFORT": args.codex_reasoning_effort,
        "CLAUDE_MODEL": args.claude_model,
        "CLAUDE_REASONING_EFFORT": args.claude_effort,
    }
    for key, value in cli_values.items():
        if value is not None:
            config[key] = value
    if args.open_after_save is not None:
        config["OPEN_AFTER_SAVE"] = "true" if args.open_after_save else "false"
    if args.verbose:
        config["LOG_LEVEL"] = "debug"

    return config


def validate_dependencies(config: dict[str, str], args: argparse.Namespace) -> None:
    if shutil.which("python3") is None:
        raise UserError("Missing dependency: python3", 127)
    if not args.transcript_file and importlib.util.find_spec("youtube_transcript_api") is None:
        raise UserError(
            "Missing dependency: youtube-transcript-api. Install it with: "
            "python3 -m pip install youtube-transcript-api",
            127,
        )
    if config["PROVIDER"] == "codex" and shutil.which("codex") is None:
        raise UserError("Missing dependency: codex", 127)
    if config["PROVIDER"] == "claude" and shutil.which("claude") is None:
        raise UserError("Missing dependency: claude", 127)


def apply_legacy_keys(config: dict[str, str], source: dict[str, str]) -> None:
    if "SUBTITLE_LANGS" in source and "PREFERRED_TRANSCRIPT_LANGS" not in source:
        config["PREFERRED_TRANSCRIPT_LANGS"] = source["SUBTITLE_LANGS"]
    if "ALLOW_ANY_SUBTITLE_LANGUAGE" in source and "ALLOW_ANY_TRANSCRIPT_LANGUAGE" not in source:
        config["ALLOW_ANY_TRANSCRIPT_LANGUAGE"] = source["ALLOW_ANY_SUBTITLE_LANGUAGE"]
    if "SUMMARY_LANGUAGE" in source and "OUTPUT_LANGUAGE" not in source:
        config["OUTPUT_LANGUAGE"] = source["SUMMARY_LANGUAGE"]


def resolve_prompt_template(value: str) -> Path:
    path = expand_path(value) if "/" in value or value.startswith("~") else PROJECT_ROOT / "prompts" / value
    if path.suffix == "":
        path = path.with_suffix(".md")
    if not path.exists():
        raise UserError(f"Prompt template does not exist: {path}")
    return path.resolve()


def resolve_provider(value: str) -> Path:
    path = expand_path(value) if "/" in value or value.startswith("~") else PROJECT_ROOT / "providers" / f"{value}.sh"
    if not path.exists():
        raise UserError(f"Provider does not exist: {path}")
    if not os.access(path, os.X_OK):
        raise UserError(f"Provider is not executable: {path}")
    return path.resolve()


def ensure_writable_dir(output_dir: Path) -> None:
    output_dir.mkdir(parents=True, exist_ok=True)
    if not output_dir.is_dir():
        raise UserError(f"Output path is not a directory: {output_dir}")
    try:
        with tempfile.NamedTemporaryFile(prefix=".tubefold-write-test-", dir=output_dir, delete=True):
            pass
    except OSError as error:
        raise UserError(f"Output directory is not writable: {output_dir}: {error}") from error


def run_checked(command: list[str], logger: Logger, env: dict[str, str] | None = None) -> subprocess.CompletedProcess[str]:
    logger.debug("$ " + " ".join(command))
    completed = subprocess.run(command, text=True, capture_output=True, env=env)
    if logger.verbose and completed.stdout.strip():
        logger.debug(completed.stdout.strip())
    if completed.returncode != 0:
        message = completed.stderr.strip() or completed.stdout.strip() or f"exit code {completed.returncode}"
        raise UserError(message, completed.returncode or 1)
    if logger.verbose and completed.stderr.strip():
        logger.debug(completed.stderr.strip())
    return completed


def write_fallback_metadata(path: Path, video_id: str, url: str) -> None:
    path.write_text(
        json.dumps(
            {
                "id": video_id,
                "title": video_id,
                "webpage_url": url,
                "channel": "",
                "duration": None,
                "upload_date": "",
            },
            ensure_ascii=False,
            indent=2,
        )
        + "\n",
        encoding="utf-8",
    )


def transcript_language_label(transcript_info: dict[str, Any]) -> str:
    language = str(transcript_info.get("language") or "").strip()
    code = str(transcript_info.get("language_code") or "").strip()
    generated = "auto" if transcript_info.get("is_generated") else "manual"
    if language and code and language != code:
        return f"{language} ({code}, {generated})"
    return f"{code or language or 'unknown'} ({generated})"


def build_markdown(
    fields: dict[str, Any],
    transcript_info: dict[str, Any],
    provider_name: str,
    prompt_template: Path,
    response: str,
    config: dict[str, str],
) -> str:
    model = provider_name
    if provider_name == "codex":
        model = model_label("codex", config["CODEX_MODEL"], config["CODEX_REASONING_EFFORT"])
    elif provider_name == "claude":
        model = model_label("claude", config["CLAUDE_MODEL"], config["CLAUDE_REASONING_EFFORT"])

    metadata = {
        "type": "tubefold",
        "source": "youtube",
        "video_id": fields["video_id"],
        "url": fields["url"],
        "title": fields["title"],
        "channel": fields["channel"],
        "duration_seconds": fields["duration_seconds"],
        "published_at": fields["published_at"],
        "processed_at": processed_at_now(),
        "subtitle_language": transcript_info.get("language_code", ""),
        "transcript_language": transcript_info.get("language", ""),
        "transcript_language_code": transcript_info.get("language_code", ""),
        "transcript_is_generated": bool(transcript_info.get("is_generated")),
        "output_language": config["OUTPUT_LANGUAGE"],
        "model": model,
        "prompt_template": prompt_template.stem,
    }
    front_matter = yaml_front_matter(
        metadata
    )
    return front_matter + response.strip() + "\n" + tubefold_footer_markdown()


if __name__ == "__main__":
    raise SystemExit(main())
