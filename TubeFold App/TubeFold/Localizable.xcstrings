          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ابھی تک کوئی تجزیہ ریکارڈ نہیں ہوا۔ آپ کے پہلے خلاصے کے بعد ٹوکن استعمال یہاں ظاہر ہوگا۔"
          }
        }
      }
