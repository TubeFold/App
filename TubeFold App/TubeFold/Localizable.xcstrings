    "When a summary is ready, publish it to Telegraph and open the page in your browser.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда сводка готова, публиковать ее в Telegraph и открывать страницу в браузере."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "摘要准备好后，将其发布到 Telegraph 并在浏览器中打开页面。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "सारांश तैयार होने पर, उसे Telegraph पर प्रकाशित करें और पेज को अपने ब्राउज़र में खोलें।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando un resumen esté listo, publícalo en Telegraph y abre la página en tu navegador."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lorsqu’un résumé est prêt, publiez-le sur Telegraph et ouvrez la page dans votre navigateur."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "عندما يكون الملخص جاهزًا، انشره على Telegraph وافتح الصفحة في متصفحك."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সারাংশ প্রস্তুত হলে, সেটি Telegraph-এ প্রকাশ করুন এবং পৃষ্ঠাটি আপনার ব্রাউজারে খুলুন।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Quando um resumo estiver pronto, publique-o no Telegraph e abra a página no navegador."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "جب خلاصہ تیار ہو، اسے Telegraph پر شائع کریں اور صفحہ اپنے براؤزر میں کھولیں۔"
          }
        }
      }
    },
