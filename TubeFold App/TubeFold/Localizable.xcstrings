            "value": "Esperando videos"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "En attente de vidéos"
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بانتظار الفيديوهات"
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "ভিডিওর অপেক্ষায়"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Aguardando vídeos"
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ویڈیوز کا انتظار ہے"
          }
        }
      }
    },
    "We ask %@ for a short fixed response to confirm it is signed in and ready.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мы просим %@ дать короткий фиксированный ответ, чтобы подтвердить, что вход выполнен и все готово."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我们会要求 %@ 返回一个简短的固定响应，以确认它已登录并准备就绪。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हम %@ से एक छोटा निश्चित जवाब मांगते हैं ताकि पुष्टि हो सके कि साइन इन है और तैयार है।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pedimos a %@ una respuesta breve y fija para confirmar que tiene sesión iniciada y está listo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous demandons à %@ une courte réponse fixe pour confirmer qu’il est connecté et prêt."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نطلب من %@ ردًا قصيرًا وثابتًا للتأكد من أنه مسجّل الدخول وجاهز."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "সাইন ইন করা এবং প্রস্তুত কিনা নিশ্চিত করতে আমরা %@-কে একটি সংক্ষিপ্ত নির্দিষ্ট উত্তর দিতে বলি।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Pedimos a %@ uma resposta curta e fixa para confirmar que está conectado e pronto."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ہم %@ سے ایک مختصر مقررہ جواب مانگتے ہیں تاکہ تصدیق ہو سکے کہ سائن اِن ہے اور تیار ہے۔"
          }
        }
      }
    },
    "We look for %@ and verify the executable with a version check.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Мы ищем %@ и проверяем исполняемый файл через проверку версии."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我们会查找 %@，并通过版本检查来验证可执行文件。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "हम %@ को ढूंढते हैं और संस्करण जांच से एक्जीक्यूटेबल सत्यापित करते हैं।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Buscamos %@ y verificamos el ejecutable con una comprobación de versión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous recherchons %@ et vérifions l’exécutable avec un contrôle de version."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "نبحث عن %@ ونتحقق من الملف التنفيذي عبر فحص الإصدار."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "আমরা %@ খুঁজি এবং সংস্করণ পরীক্ষা দিয়ে এক্সিকিউটেবল যাচাই করি।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Procuramos %@ e verificamos o executável com uma checagem de versão."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "ہم %@ تلاش کرتے ہیں اور ورژن چیک کے ذریعے ایگزیکیوٹیبل کی تصدیق کرتے ہیں۔"
          }
        }
      }
    },
