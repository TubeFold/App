    "Make sure %@ is installed and signed in. TubeFold will find it automatically, or you can choose the executable yourself." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تأكد من تثبيت %@ وتسجيل الدخول إليه. سيعثر عليه TubeFold تلقائيًا، أو يمكنك اختيار الملف التنفيذي بنفسك."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "নিশ্চিত করুন %@ ইনস্টল করা আছে এবং সাইন ইন করা হয়েছে। TubeFold এটি স্বয়ংক্রিয়ভাবে খুঁজে পাবে, অথবা আপনি নিজেই এক্সিকিউটেবল বেছে নিতে পারেন।"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Asegúrate de que %@ esté instalado y con sesión iniciada. TubeFold lo encontrará automáticamente, o puedes elegir el ejecutable manualmente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Assurez-vous que %@ est installé et connecté. TubeFold le trouvera automatiquement, ou vous pouvez choisir l’exécutable vous-même."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सुनिश्चित करें कि %@ इंस्टॉल है और उसमें साइन इन है। TubeFold इसे अपने आप ढूंढ लेगा, या आप खुद एक्जीक्यूटेबल चुन सकते हैं।"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verifique se %@ está instalado e com sessão iniciada. O TubeFold o encontrará automaticamente, ou você pode escolher o executável manualmente."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Убедитесь, что %@ установлен и выполнен вход. TubeFold найдет его автоматически, или вы можете выбрать исполняемый файл вручную."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "یقینی بنائیں کہ %@ انسٹال ہے اور اس میں سائن اِن ہے۔ TubeFold اسے خودکار طور پر تلاش کرے گا، یا آپ خود ایگزیکیوٹیبل منتخب کر سکتے ہیں۔"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
