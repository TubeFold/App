    "TubeFold uses a signed-in CLI on this Mac to write summaries. Both options use your own subscription — no API key is needed.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "TubeFold создает сводки через CLI на этом Mac, где уже выполнен вход. Оба варианта используют вашу подписку, API-ключ не нужен."
          }
        }
      }
    },
    "Usage": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Использование"
          }
        }
      }
    },
    "Used for new summaries. Existing Markdown files stay unchanged.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Используется для новых сводок. Существующие Markdown-файлы не изменятся."
