{
  "sourceLanguage" : "en",
  "strings" : {
    "“%@” and its generated summary will be removed from your Library. This can't be undone." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ستتم إزالة “%@” وملخصه المُنشأ من مكتبتك. لا يمكن التراجع عن هذا الإجراء."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” এবং এর তৈরি করা সারাংশ আপনার লাইব্রেরি থেকে সরানো হবে। এটি পূর্বাবস্থায় ফেরানো যাবে না।"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” y su resumen generado se eliminarán de tu biblioteca. Esta acción no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "« %@ » et son résumé généré seront retirés de votre bibliothèque. Cette action est irréversible."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” और उसका जनरेट किया गया सारांश आपकी लाइब्रेरी से हटाया जाएगा। यह कार्रवाई वापस नहीं की जा सकती।"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” e o resumo gerado serão removidos da sua biblioteca. Esta ação não pode ser desfeita."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«%@» и сгенерированная сводка будут удалены из библиотеки. Это действие нельзя отменить."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” اور اس کا بنایا گیا خلاصہ آپ کی لائبریری سے ہٹا دیا جائے گا۔ یہ عمل واپس نہیں لیا جا سکتا۔"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@”及其生成的摘要将从你的资料库中移除。此操作无法撤销。"
          }
        }
      }
    },
    "%@ is ready. You can reopen this setup any time from Settings." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ جاهز. يمكنك إعادة فتح هذا الإعداد في أي وقت من الإعدادات."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ প্রস্তুত। আপনি সেটিংস থেকে যেকোনো সময় এই সেটআপ আবার খুলতে পারেন।"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ está listo. Puedes volver a abrir esta configuración en cualquier momento desde Ajustes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ est prêt. Vous pouvez rouvrir cette configuration à tout moment depuis Réglages."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ तैयार है। आप इस सेटअप को कभी भी सेटिंग्स से फिर से खोल सकते हैं।"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ está pronto. Você pode reabrir esta configuração a qualquer momento em Ajustes."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ готов. Вы можете снова открыть эту настройку в любое время из Настроек."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ تیار ہے۔ آپ اس سیٹ اپ کو کسی بھی وقت ترتیبات سے دوبارہ کھول سکتے ہیں۔"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "%@ 已准备就绪。你可以随时从“设置”重新打开此设置。"
          }
        }
      }
    },
