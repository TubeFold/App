    "Install the Chrome extension to send videos straight from a YouTube page — one click, no copy-paste.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Установите расширение Chrome, чтобы отправлять видео прямо со страницы YouTube: один клик, без копирования ссылок."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "安装 Chrome 扩展，即可直接从 YouTube 页面发送视频：一次点击，无需复制粘贴。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "YouTube पेज से सीधे वीडियो भेजने के लिए Chrome एक्सटेंशन इंस्टॉल करें — एक क्लिक, कॉपी-पेस्ट नहीं।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Instala la extensión de Chrome para enviar videos directamente desde una página de YouTube: un clic, sin copiar y pegar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Installez l’extension Chrome pour envoyer des vidéos directement depuis une page YouTube : un clic, sans copier-coller."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ثبّت إضافة Chrome لإرسال الفيديوهات مباشرة من صفحة YouTube: نقرة واحدة، بلا نسخ ولصق."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "YouTube পৃষ্ঠা থেকে সরাসরি ভিডিও পাঠাতে Chrome এক্সটেনশন ইনস্টল করুন: এক ক্লিক, কপি-পেস্ট নয়।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Instale a extensão do Chrome para enviar vídeos diretamente de uma página do YouTube: um clique, sem copiar e colar."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "YouTube صفحے سے براہ راست ویڈیوز بھیجنے کے لیے Chrome ایکسٹینشن انسٹال کریں: ایک کلک، کاپی پیسٹ نہیں۔"
          }
        }
      }
    },
