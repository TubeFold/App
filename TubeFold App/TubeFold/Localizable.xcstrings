    "Paste a YouTube link above, or send one from the Chrome extension, and it will appear here.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вставьте ссылку YouTube выше или отправьте ее из расширения Chrome, и она появится здесь."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在上方粘贴 YouTube 链接，或从 Chrome 扩展发送链接，它就会显示在这里。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ऊपर YouTube लिंक चिपकाएं, या Chrome एक्सटेंशन से भेजें, और वह यहां दिखाई देगा।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Pega un enlace de YouTube arriba o envía uno desde la extensión de Chrome, y aparecerá aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Collez un lien YouTube ci-dessus, ou envoyez-en un depuis l’extension Chrome, et il apparaîtra ici."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "الصق رابط YouTube أعلاه، أو أرسله من إضافة Chrome، وسيظهر هنا."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "উপরে একটি YouTube লিঙ্ক পেস্ট করুন, অথবা Chrome এক্সটেনশন থেকে একটি পাঠান, সেটি এখানে দেখা যাবে।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Cole um link do YouTube acima ou envie um pela extensão do Chrome, e ele aparecerá aqui."
          }
        },
        "ur": {
          "stringUnit": {
            "state": "translated",
            "value": "اوپر YouTube لنک پیسٹ کریں، یا Chrome ایکسٹینشن سے بھیجیں، اور وہ یہاں ظاہر ہوگا۔"
          }
        }
      }
    },
