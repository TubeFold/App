    "Remove the TubeFold icon from the Dock and the app switcher. The main window stays available." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إزالة أيقونة TubeFold من Dock ومبدّل التطبيقات. ستبقى النافذة الرئيسية متاحة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dock এবং অ্যাপ সুইচার থেকে TubeFold আইকন সরান। প্রধান উইন্ডো উপলভ্য থাকবে।"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Elimina el icono de TubeFold del Dock y del selector de apps. La ventana principal seguirá disponible."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Retirez l’icône TubeFold du Dock et du sélecteur d’apps. La fenêtre principale reste disponible."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dock और ऐप स्विचर से TubeFold आइकन हटाएं। मुख्य विंडो उपलब्ध रहेगी।"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Remova o ícone do TubeFold do Dock e do alternador de apps. A janela principal continuará disponível."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Скрыть значок TubeFold из Dock и переключателя приложений. Главное окно останется доступным."
          }
        },
        "ur" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TubeFold آئیکن کو Dock اور ایپ سوئچر سے ہٹا دیں۔ مرکزی ونڈو دستیاب رہے گی۔"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "从 Dock 和 App 切换器中移除 TubeFold 图标。主窗口仍然可用。"
          }
        }
      }
    },
