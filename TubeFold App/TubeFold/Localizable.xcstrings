    "No analyses recorded yet. Token usage appears here after your first summary.": {
      "localizations": {
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Анализов пока нет. Расход токенов появится здесь после первой сводки."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "尚未记录任何分析。首次摘要后，令牌用量会显示在这里。"
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अभी तक कोई विश्लेषण रिकॉर्ड नहीं हुआ है। आपके पहले सारांश के बाद टोकन उपयोग यहां दिखाई देगा।"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Aún no se han registrado análisis. El uso de tokens aparecerá aquí después de tu primer resumen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucune analyse enregistrée pour le moment. L’utilisation des jetons apparaîtra ici après votre premier résumé."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يتم تسجيل أي تحليلات بعد. سيظهر استخدام الرموز هنا بعد أول ملخص."
          }
        },
        "bn": {
          "stringUnit": {
            "state": "translated",
            "value": "এখনও কোনো বিশ্লেষণ রেকর্ড করা হয়নি। আপনার প্রথম সারাংশের পর টোকেন ব্যবহার এখানে দেখা যাবে।"
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
